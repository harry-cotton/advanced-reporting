# Secrets — never commit
.env
*.env
config/config.yaml
config/engagement.yaml
secrets/
*.key

# Data & generated outputs
data/raw/*
data/interim/*
data/processed/*
outputs/*
!**/.gitkeep

# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/

# OS / editor
.DS_Store
.vscode/
.idea/

# Repo snapshots — GitHub is the transfer mechanism, never a bundle in the repo
*.bundle

# Claude Code local settings (machine-specific)
.claude/settings.local.json
data/inbox/*

# generated draft from scripts/naming_report.py (not a committed artifact)
config/naming_overrides.suggested.yaml

# agent-system per-client context — confidential, like data/ (see system/README.md)
system/context/*
!system/context/README.md
!system/context/client_brief.template.md

# demo/client datasets (data policy: data never enters git)
data/recruitment_demo/
data/MMM Data/
data/archive/

# Office lock files
~$*
