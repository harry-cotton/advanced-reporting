{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dashboard",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": [
        "-m", "streamlit", "run",
        "src/advanced_reporting/dashboard/app.py",
        "--server.headless", "true",
        "--server.port", "8599"
      ],
      "port": 8599
    },
    {
      "name": "report",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "http.server", "8601", "--directory", "outputs"],
      "port": 8601
    }
  ]
}
