# Copy to .env (gitignored) and fill in. NEVER commit real secrets.
# Sources read these via DataSource.require_credentials() (loads .env, never hardcoded).

# Supermetrics — for live data pulls (Phase 2)
SUPERMETRICS_API_KEY=

# Google Ads connector (Phase 2)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Meta (Facebook/Instagram) connector (Phase 2)
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
META_AD_ACCOUNT_ID=

# TikTok Ads connector (Phase 2)
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
TIKTOK_APP_ID=
TIKTOK_SECRET=

# LinkedIn connector (Phase 2)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_AD_ACCOUNT_ID=

# GA4 (Google Analytics 4) connector — mid-funnel engagement (Phase 2)
GA4_PROPERTY_ID=

# Optional: LLM provider for richer auto-commentary
ANTHROPIC_API_KEY=
